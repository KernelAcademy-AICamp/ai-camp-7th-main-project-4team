# CODEOWNERS — 경로별 소유자. PR 시 해당 소유자에게 리뷰가 자동 요청된다.
# ⚠️ 아래 @handle을 실제 GitHub 계정으로 교체하세요(예: @lead → @gildong).
#   @lead     = 팀장   — 시드 데이터 수집
#   @designer = 디자이너 — 화면 레이아웃·디자인 컨셉
#   @dev      = 개발자   — 엔진·구현
# 규칙: 아래로 갈수록 우선(마지막 매칭이 이김).

# 기본 — 셋 공동
*                                   @lead @designer @dev
/docs/                              @lead @designer @dev

# ── 팀장: 시드 데이터 ──────────────────────────────
/data/                              @lead

# ── 개발자: 엔진·로직 ──────────────────────────────
/engine/                            @dev
/web/js/                            @dev

# ── 디자이너: 레이아웃·디자인·에셋 ─────────────────
/web/*.html                         @designer
/web/*.css                          @designer
/web/photos/                        @designer

# ── web/data: 생성물은 팀장, 표현 데이터는 디자이너 ──
#   (파일별 지정 — 위 패턴보다 뒤라 이 지정이 이김)
/web/data/garments.json             @lead
/web/data/body-base-model.json      @lead
/web/data/body-distribution.json    @lead
/web/data/archetypes.json           @lead
/web/data/bodytypes.json            @designer
