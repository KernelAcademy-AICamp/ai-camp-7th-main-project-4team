# 환경변수 템플릿 — 이 파일을 복사해 `.env.local`을 만들고 실제 값을 채운다.
#   cp .env.example .env.local
# ⚠️ .env.local은 .gitignore로 커밋 안 됨. 실제 키는 절대 커밋하지 말 것.
#    배포는 Vercel 프로젝트 환경변수(또는 Vercel↔Supabase 연동)에 동일 등록.
# 값 위치: Supabase → Project Settings → API Keys
# ※ Next 앱 스캐폴드 후엔 이 파일이 그 앱 루트로 이동(Next가 프로젝트 루트의 .env.local을 읽음).
#
# [키 체계] Supabase 신 API 키 사용(권장):
#   Secret key(sb_secret_...)      = 옛 service_role 대체 · 서버 전용 · RLS 우회
#   Publishable key(sb_publishable_...) = 옛 anon 대체 · 클라이언트 · RLS 적용
#   (레거시 JWT anon/service_role도 동작하지만 새 키 권장)

# ── 서버 전용 (측정 MVP 필수) ─────────────────────────────────────
# 진단/피드백 insert·admin 집계는 이 키로만 수행(RLS 우회). 브라우저 노출·커밋 절대 금지.
SUPABASE_URL=
SUPABASE_SECRET_KEY=            # sb_secret_...  (Secret key)

# ── 클라이언트용 (admin 대시보드 등 — 나중) ───────────────────────
# 브라우저에서 Supabase 직접 접근 시. (Next는 노출 변수에 NEXT_PUBLIC_ 접두사 필요)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...  (Publishable key)

# ── Anthropic (판정 사진 첨부 = 사이즈표 캡처 인식) ────────────────
# 사용자가 올린 사이즈표 이미지를 읽어 JSON으로 만드는 서버 호출에만 사용.
# 쓰는 곳: api/parse-size-table.js — 판정(Fit)에서 사진 첨부 시 호출.
# 없어도 dev:api는 뜨고 진단·판정·피드백은 정상. 사진 첨부만 500으로
# 끊기고 '직접 입력' 폴백으로 떨어진다(화면 개발만 할 땐 비워도 됨).
# 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지(브라우저 노출 시 키 유출).
# 값 위치: platform.claude.com → API Keys
ANTHROPIC_API_KEY=              # sk-ant-...
